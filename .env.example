# GAWER Intelligence — variables de entorno
#
# Copiar a .env.local (nunca commitear ese archivo) y completar con los valores reales del
# proyecto de Supabase solo cuando se decida activar el modo real (OPERATIVO-REAL-1).
#
# Mientras estas variables no estén definidas, la aplicación sigue funcionando 100% en modo
# local (.local-data/gawer/proposals.json), sin ningún cambio de comportamiento. Además, aunque
# se definan, el modo Supabase no queda operativo hasta aplicar manualmente la migración SQL en
# docs/supabase/OPERATIVO-REAL-1-proposals-schema.sql.

# URL del proyecto Supabase (Project Settings > API).
NEXT_PUBLIC_SUPABASE_URL=

# Anon/public key (Project Settings > API). Segura para exponer en el cliente, pero no se usa
# todavía en esta fase: no hay acceso directo desde el navegador a Supabase.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (Project Settings > API). SOLO server-side: nunca exponer al cliente, nunca
# loguear, nunca commitear un valor real.
SUPABASE_SERVICE_ROLE_KEY=
